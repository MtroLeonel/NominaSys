# ==================================
# CONFIGURACIÓN DEL SERVIDOR
# ==================================
PORT=3000
NODE_ENV=development

# ==================================
# CONFIGURACIÓN DE BASE DE DATOS
# ==================================
DB_DIALECT=postgres
DB_SSL_MODE=require
# Host de la base de datos
DB_HOST=localhost

# Puerto para PostgreSQL
DB_PORT=5432

# SSL para PostgreSQL administrado (por ejemplo Neon, Supabase, Render)
# Usa 'require' para forzar SSL
# DB_SSL_MODE=require

# Usuario de la base de datos
DB_USER=postgres

# Contraseña de la base de datos
DB_PASSWORD=tu_contraseña

# Nombre de la base de datos
DB_NAME=practicanomina

# ==================================
# OPCIONES AVANZADAS (OPCIONAL)
# ==================================

# Mostrar queries SQL en consola (true/false)
# DB_LOGGING=true

#jwt secret y expiración
JWT_SECRET =qwerty12345*@
JWT_EXPIRES_IN=1h
# CORS
CORS_ORIGINS=https://nominasys.fly.dev,http://localhost:56758