# ==================================
# CONFIGURACIÓN DEL SERVIDOR
# ==================================
PORT=3000
NODE_ENV=development

# ==================================
# CONFIGURACIÓN DE BASE DE DATOS
# ==================================

# Dialecto de base de datos: 'mysql' o 'mssql'
DB_DIALECT=mysql

# Host de la base de datos
DB_HOST=localhost

# Puerto (3306 para MySQL, 1433 para MSSQL)
DB_PORT=3306

# Usuario de la base de datos
DB_USER=root

# Contraseña de la base de datos
DB_PASSWORD=tu_contraseña

# Nombre de la base de datos
DB_NAME=practicanomina

# ==================================
# CONFIGURACIÓN ALTERNATIVA: SQL SERVER
# ==================================
# Para usar SQL Server, cambia los valores anteriores a:
# DB_DIALECT=mssql
# DB_HOST=localhost
# DB_PORT=1433
# DB_USER=sa
# DB_PASSWORD=tu_contraseña
# DB_NAME=practicanomina

# ==================================
# OPCIONES AVANZADAS (OPCIONAL)
# ==================================

# Mostrar queries SQL en consola (true/false)
# DB_LOGGING=true
