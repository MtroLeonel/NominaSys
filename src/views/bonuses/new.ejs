<section class="section">
  <div class="container">
    <h1 class="title">Nuevo bono</h1>
    <form action="/bonos" method="POST" class="box">
      <div class="field">
        <label class="label">Nombre</label>
        <div class="control">
          <input class="input" type="text" name="name" required />
        </div>
      </div>
      <div class="field">
        <label class="label">Tipo de monto</label>
        <div class="control">
          <div class="select">
            <select name="amountType" required>
              <option value="fixed">Fijo</option>
              <option value="percent">Porcentaje</option>
            </select>
          </div>
        </div>
      </div>
      <div class="field">
        <label class="label">Monto</label>
        <div class="control">
          <input class="input" type="number" step="0.01" name="amount" required />
        </div>
      </div>
      <div class="field">
        <label class="checkbox">
          <input type="checkbox" name="active" checked /> Activo
        </label>
      </div>
      <div class="field is-grouped">
        <div class="control">
          <button class="button is-primary" type="submit">Guardar</button>
        </div>
        <div class="control">
          <a class="button is-light" href="/bonos">Cancelar</a>
        </div>
      </div>
    </form>
  </div>
</section>
