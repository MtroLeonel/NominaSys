<section class="section">
  <div class="container">
    <div class="level">
      <div class="level-left">
        <h1 class="title">Periodos de nómina</h1>
      </div>
      <div class="level-right">
        <a class="button is-primary" href="/payroll/new">Nuevo</a>
      </div>
    </div>
    <table class="table is-fullwidth is-striped">
      <thead>
        <tr>
          <th>Tipo</th>
          <th>Inicio</th>
          <th>Fin</th>
          <th>Estado</th>
          <th>Creado</th>
        </tr>
      </thead>
      <tbody>
        <% periods.forEach(p => { %>
          <tr>
            <td><%= p.type %></td>
            <td><%= p.startDate %></td>
            <td><%= p.endDate %></td>
            <td><%= p.status %></td>
            <td><%= p.createdAt.toISOString().slice(0,10) %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>
